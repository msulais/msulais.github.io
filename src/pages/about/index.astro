---
import CSplash from './_components/Splash.astro'
import CHeader from './_components/Header.astro'
import CHero from './_components/Hero.astro'
import CAbout from './_components/About.astro'
import CProjects from './_components/Projects.astro'
import CFooter from './_components/Footer.astro'
import * as SharedIds from './_scripts/shared/ids.enum.js'
import './_styles/global.scss'
---
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Muhammad Sulais</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&family=Google+Sans+Code:ital,wght,MONO@0,300..800,1;1,300..800,1&display=swap">
	<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0">
	<link rel="icon" href="/favicon.svg">
</head>
<body>
	<CSplash/>
	<div
		style={{'display': 'none' }}
		id={SharedIds.Body}>
		<CHeader/>
		<main style="min-height:100dvh;">
			<CHero/>
			<div style="display:flex;flex-direction: column; align-items: center;width: 100%;">
				<CAbout/>
				<CProjects/>
			</div>
		</main>
		<CFooter/>
	</div>
	<script src="./_scripts/index.ts"/>
</body>
</html>